{
  "name": "@walkie-talkie/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI application for Walkie-Talkie",
  "main": "dist/apps/cli/src/index.js",
  "types": "dist/apps/cli/src/index.d.ts",
  "bin": {
    "walkie-talkie": "bin/walkie-talkie.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --experimental-strip-types --enable-source-maps src/index.ts",
    "test:smoke": "node --test --experimental-strip-types ../../tests/cli/install.command.test.ts",
    "start:dist": "node dist/apps/cli/src/index.js"
  }
}
